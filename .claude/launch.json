{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-l", "3000", "."],
      "port": 3000
    },
    {
      "name": "static-http-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", ".", "-p", "8080", "-c-1"],
      "port": 8080
    },
    {
      "name": "python-http",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
